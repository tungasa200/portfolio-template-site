# Copy to .env and fill in. See README.md "External service setup" for how
# to obtain each value.

# --- Database (Neon Postgres) -----------------------------------------------
# Use Neon's *pooled* connection string (PgBouncer, port 5432 with
# "-pooler" in the host) — this app runs on Vercel serverless functions.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# --- Routing -----------------------------------------------------------------
# The apex domain tenants are served under, e.g. "myplatform.com".
# Locally, leave as localhost:3000 — {slug}.localhost:3000 resolves to
# 127.0.0.1 automatically in Chrome/Firefox, no /etc/hosts edits needed.
ROOT_DOMAIN="localhost:3000"

# --- Auth (Auth.js / NextAuth v5) --------------------------------------------
# Generate with: npx auth secret
AUTH_SECRET=""

# --- Cloudflare R2 (S3-compatible object storage) ----------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Custom domain proxied through Cloudflare in front of the bucket, so
# next/image can fetch photos (see next.config.ts images.remotePatterns).
R2_PUBLIC_HOSTNAME="images.myplatform.com"
