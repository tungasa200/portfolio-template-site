# Copy to .env and fill in. See README.md "External service setup" for how
# to obtain each value.

# --- Database (Neon Postgres) -----------------------------------------------
# Neon gives you two connection strings for the same database — copy both:
#
# DATABASE_URL: the *pooled* one (hostname has "-pooler" in it). The app's
# own PrismaClient (src/lib/db/client.ts) connects with this at runtime —
# required on Vercel serverless, which opens many short-lived connections.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
#
# DIRECT_URL: the *direct* one (no "-pooler"). Only the Prisma CLI reads this
# (see prisma.config.ts) — `prisma migrate`/`db push` need a direct
# connection because PgBouncer's pooling mode doesn't support the advisory
# locks schema migrations take.
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Routing -----------------------------------------------------------------
# The apex domain tenants are served under, e.g. "myplatform.com".
# Locally, leave as localhost:3000 — {slug}.localhost:3000 resolves to
# 127.0.0.1 automatically in Chrome/Firefox, no /etc/hosts edits needed.
ROOT_DOMAIN="localhost:3000"

# --- Auth (Auth.js / NextAuth v5) --------------------------------------------
# Generate with: npx auth secret
AUTH_SECRET=""

# --- Cloudflare R2 (S3-compatible object storage) ----------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Custom domain proxied through Cloudflare in front of the bucket, so
# next/image can fetch photos (see next.config.ts images.remotePatterns).
R2_PUBLIC_HOSTNAME="images.myplatform.com"
