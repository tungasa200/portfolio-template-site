# Copy to .env and fill in. See README.md "External service setup" for how
# to obtain each value.

# --- Database (Neon Postgres) -----------------------------------------------
# Two DIFFERENT roles, not just two connection strings for the same one:
#
# DATABASE_URL: the *pooled* (hostname has "-pooler") connection, as the
# dedicated `app_runtime` role (prisma/security/create-app-role.sql — run
# that once per database first, it's not automatic). The app's own
# PrismaClient (src/lib/db/client.ts) connects with this at runtime —
# required on Vercel serverless, which opens many short-lived connections.
# Must NOT be the Neon owner role: that role has BYPASSRLS by default, which
# silently makes prisma/security/rls.sql's policies a no-op (confirmed
# 2026-07-14 — see create-app-role.sql's comment for how this was found).
DATABASE_URL="postgresql://app_runtime:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
#
# DIRECT_URL: the *direct* (no "-pooler") connection, as the Neon owner role
# (e.g. neondb_owner). Read by the Prisma CLI (see prisma.config.ts —
# `prisma migrate`/`db push` need a direct connection because PgBouncer's
# pooling mode doesn't support the advisory locks schema migrations take)
# and by prisma/seed.ts, which writes rows directly without going through
# forTenant()'s SET LOCAL and would be blocked by RLS under the restricted
# role.
DIRECT_URL="postgresql://neondb_owner:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Routing -----------------------------------------------------------------
# The apex domain tenants are served under, e.g. "myplatform.com".
# Locally, leave as localhost:3000 — {slug}.localhost:3000 resolves to
# 127.0.0.1 automatically in Chrome/Firefox, no /etc/hosts edits needed.
ROOT_DOMAIN="localhost:3000"

# --- Auth (Auth.js / NextAuth v5) --------------------------------------------
# `npx auth secret` resolves to the unrelated "Better Auth" CLI package and
# writes BETTER_AUTH_SECRET (wrong variable) — don't use it. Generate one
# directly instead:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# --- Cloudflare R2 (S3-compatible object storage) ----------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# S3 API endpoint for the account (Cloudflare dashboard -> R2 -> bucket ->
# Settings shows this): https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT="https://xxxx.r2.cloudflarestorage.com"
# Custom domain proxied through Cloudflare in front of the bucket, so
# next/image can fetch photos (see next.config.ts images.remotePatterns).
# Leave blank until Phase 4 (upload flow) — not required yet.
R2_PUBLIC_HOSTNAME="images.myplatform.com"
