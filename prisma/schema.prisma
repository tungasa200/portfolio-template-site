// Prisma schema — multi-tenant photographer portfolio SaaS
// See docs/architecture.md and docs/decisions.md for the reasoning behind
// this structure.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Platform-level models
// ---------------------------------------------------------------------------

enum TenantPlan {
  FREE
}

enum CustomDomainStatus {
  NONE
  PENDING
  VERIFIED
  FAILED
}

model Tenant {
  id                 String             @id @default(uuid())
  slug               String             @unique
  customDomain       String?            @unique
  customDomainStatus CustomDomainStatus @default(NONE)
  planTier           TenantPlan         @default(FREE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users              User[]
  siteSettings       SiteSettings?
  aboutPage          AboutPage?
  navItems           NavItem[]
  socialLinks        SocialLink[]
  boards             Board[]
  boardItems         BoardItem[]
  boardItemPhotos    BoardItemPhoto[]
  contactSubmissions ContactSubmission[]
}

enum UserRole {
  TENANT_OWNER
  TENANT_ADMIN
  PLATFORM_SUPERADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(TENANT_OWNER)
  createdAt    DateTime @default(now())

  // Brute-force lockout (see docs/decisions.md#authjs-self-hosted-not-clerk).
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Null only for PLATFORM_SUPERADMIN — every tenant-facing user belongs to exactly one tenant.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Tenant-scoped content models
// Every model below carries `tenantId` directly (denormalized even where a
// parent relation could derive it) so the forTenant() guardrail can filter
// every table without relying on a correct join. See lib/db/tenant-scoped-client.ts.
// ---------------------------------------------------------------------------

model SiteSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  siteName         String
  photographerName String
  heroImageKey     String?
  contactEmail     String
  footerText       String?
  themeName        String  @default("editorial-default") // reserved for future per-tenant theming
}

// Static, non-repeating page — not a board (no items, no photo grid).
model AboutPage {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  content String @db.Text // trusted admin-authored rich HTML
}

enum NavTargetKind {
  HOME
  ABOUT
  CONTACT
  BOARD
  EXTERNAL_URL
}

model NavItem {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Used for HOME/ABOUT/CONTACT/EXTERNAL_URL. For BOARD targets this column
  // is present but not authoritative — render with targetBoard.name instead
  // (see src/lib/site/nav-items.ts's resolveNavLabel) so a board rename
  // can't drift out of sync with its own nav entry.
  label         String
  targetKind    NavTargetKind
  targetBoardId String? // set iff targetKind == BOARD
  targetBoard   Board?        @relation(fields: [targetBoardId], references: [id], onDelete: Cascade)
  url           String? // set iff targetKind == EXTERNAL_URL
  order         Int
  isVisible     Boolean       @default(true)

  @@index([tenantId, order])
}

model SocialLink {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  platform String
  url      String
  order    Int

  @@index([tenantId, order])
}

enum BoardKind {
  GALLERY_MULTI // item has N photos + its own detail page (INDEX/GRID/FULLSCREEN tabs)
  GALLERY_SINGLE // item has exactly 1 photo, no detail page, grid-only static tile
}

model Board {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Stable per-tenant sequence driving the fixed /board/{seq} route — set
  // once at creation, never user-editable (URL paths are intentionally
  // frozen; only `name` is editable — see docs/progress.md's 2026-07-15 note).
  seq         Int
  name        String
  kind        BoardKind @default(GALLERY_MULTI)
  order       Int
  isPublished Boolean   @default(true)

  items    BoardItem[]
  navItems NavItem[]

  @@unique([tenantId, seq])
  @@index([tenantId, order])
}

model BoardItem {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  // Only meaningful for GALLERY_MULTI (drives the item's detail-page URL).
  // Set once on create via slugify(name) — must NEVER be re-derived on
  // update, or renaming an item silently breaks its own bookmarked/shared
  // detail URL (the exact failure mode board-path editing was removed for).
  slug String?

  name         String
  dateValue    String? // "YYYY-MM"
  order        Int
  isPublished  Boolean @default(false)
  // Only meaningful for GALLERY_MULTI.
  indexEnabled Boolean @default(false)
  indexContent String? @db.Text // trusted admin-authored rich HTML

  photos BoardItemPhoto[]

  @@unique([tenantId, boardId, slug])
  @@index([tenantId, boardId, order])
}

model BoardItemPhoto {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  boardItemId String
  boardItem   BoardItem @relation(fields: [boardItemId], references: [id], onDelete: Cascade)

  r2Key     String
  // Thumbnail/cover-photo selection — independent of display `order` (an
  // admin can star any photo as primary without reordering the grid).
  isPrimary Boolean @default(false)
  order     Int
  width     Int
  height    Int

  @@index([tenantId])
  @@index([boardItemId, order])
}

enum ContactStatus {
  NEW
  READ
  ARCHIVED
}

model ContactSubmission {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String
  email           String
  message         String        @db.Text
  attachmentR2Key String?
  status          ContactStatus @default(NEW)
  createdAt       DateTime      @default(now())

  @@index([tenantId, status])
}
